# offmute-v2 environment variables. Copy to .env or export in your shell.
# Keys are read from the environment, but can also be injected via the library API
# (apiKeys option) — injected keys always override the environment.

# Required: multimodal transcription (Gemini). Either works.
GEMINI_API_KEY=
# GOOGLE_API_KEY=

# Required: timestamped transcription (AssemblyAI Universal-2).
ASSEMBLYAI_API_KEY=

# Optional: speaker identification (level 3). DeepSeek is cheap and strong for text.
DEEPSEEK_API_KEY=

# Optional alternative/fallback providers (not used by default pipeline).
# OPENAI_API_KEY=
# GROQ_API_KEY=
# ANTHROPIC_API_KEY=

# offmute-v2 API keys (copy to .env or export in your shell).
# Only the providers you actually use are required.

# Multimodal understanding (diarization, names, tone). GOOGLE_API_KEY also works.
GEMINI_API_KEY=

# Word-level timing track (default ASR). Get one at https://www.assemblyai.com/
ASSEMBLYAI_API_KEY=

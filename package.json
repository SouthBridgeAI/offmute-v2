{
  "name": "offmute-v2",
  "version": "0.0.1",
  "description": "Best-in-class diarized meeting transcription with multimodal LLMs + timestamped alignment.",
  "author": "Southbridge",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SouthBridgeAI/offmute-v2.git"
  },
  "homepage": "https://github.com/SouthBridgeAI/offmute-v2#readme",
  "bugs": {
    "url": "https://github.com/SouthBridgeAI/offmute-v2/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "offmute-v2": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "default": "./dist/browser.browser.js"
    }
  },
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist intermediates/*.tmp"
  },
  "dependencies": {
    "@google/genai": "^1.0.0",
    "assemblyai": "^4.0.0",
    "chalk": "^5.3.0",
    "cli-progress": "^3.12.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.8.4",
    "eslint": "^9.0.0",
    "prettier": "^3.3.3",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "@ffmpeg/ffmpeg": "^0.12.0",
    "@ffmpeg/util": "^0.12.0"
  },
  "peerDependenciesMeta": {
    "@ffmpeg/ffmpeg": { "optional": true },
    "@ffmpeg/util": { "optional": true }
  }
}
